# Copy to .env for local development (Railway: set these in the service Variables tab).

DEVICE=cpu
RAILWAY_LOW_MEMORY=1
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["https://your-dashboard.vercel.app","http://localhost:3000"]

# Optional — API works without these (caching/DB features disabled)
DATABASE_URL=postgresql://user:pass@host:5432/trade_forecasting
REDIS_HOST=localhost
REDIS_PORT=6379

# Optional — GDELT BigQuery ingestion (scripts/pipelines only)
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
